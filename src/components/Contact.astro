---

---

<section
  id="contacto"
  class="py-20 bg-white min-h-screen flex flex-col justify-center"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-black text-brand-dark sm:text-4xl">
        Hablemos de su Pedido
      </h2>
      <p class="mt-4 text-lg text-gray-500">
        Cotizaciones por volumen para distribuidores y talleres a nivel
        nacional.
      </p>
    </div>

    <div
      class="max-w-5xl mx-auto bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden"
    >
      <div class="grid grid-cols-1 md:grid-cols-2">
        <!-- Columna Izquierda: Datos -->
        <div
          class="bg-brand-dark p-10 text-white flex flex-col justify-between relative overflow-hidden"
        >
          <div
            class="absolute -bottom-24 -right-24 w-64 h-64 bg-brand-primary rounded-full opacity-10 blur-3xl"
          >
          </div>

          <div class="relative z-10">
            <h3 class="text-2xl font-bold mb-6">Contacto Directo</h3>
            <p class="text-gray-300 mb-8 max-w-sm">
              Nuestro equipo de ventas comerciales le responderá a la brevedad
              con la lista de precios mayorista actualizada.
            </p>

            <div class="space-y-6">
              <a href="tel:+541112345678" class="flex items-start group">
                <div
                  class="flex-shrink-0 bg-white/5 border border-white/10 p-3 rounded-lg group-hover:bg-brand-primary group-hover:border-brand-primary transition-colors"
                >
                  <svg
                    class="w-6 h-6 text-orange-400 group-hover:text-white transition-colors"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                    ></path></svg
                  >
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-400">
                    Teléfono (Ventas)
                  </p>
                  <p class="text-lg font-semibold mt-1">+54 11 1234-5678</p>
                </div>
              </a>

              <a
                href="mailto:ventas@tc-contrapesos.com.ar"
                class="flex items-start group"
              >
                <div
                  class="flex-shrink-0 bg-white/5 border border-white/10 p-3 rounded-lg group-hover:bg-brand-primary group-hover:border-brand-primary transition-colors"
                >
                  <svg
                    class="w-6 h-6 text-orange-400 group-hover:text-white transition-colors"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    ></path></svg
                  >
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-400">
                    Correo Electrónico
                  </p>
                  <p
                    class="text-lg font-semibold mt-1 group-hover:text-brand-primary transition-colors"
                  >
                    ventas@tc-contrapesos.com.ar
                  </p>
                </div>
              </a>

              <div class="flex items-start">
                <div
                  class="flex-shrink-0 bg-white/5 border border-white/10 p-3 rounded-lg"
                >
                  <svg
                    class="w-6 h-6 text-gray-400"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    ></path><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
                  >
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-400">
                    Planta Industrial
                  </p>
                  <p class="text-lg font-semibold mt-1">
                    Parque Industrial Pilar<br /><span
                      class="text-sm text-gray-400"
                      >Buenos Aires, Argentina</span
                    >
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Columna Derecha: Formulario -->
        <div class="p-10 bg-orange-50/30">
          <form action="#" method="POST" class="space-y-6">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700"
                >Nombre completo</label
              >
              <div class="mt-1">
                <input
                  type="text"
                  name="name"
                  id="name"
                  class="py-3 px-4 block w-full shadow-sm focus:ring-brand-primary focus:border-brand-primary border-gray-300 rounded-md bg-white border outline-none"
                  placeholder="Ej: Juan Pérez"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700"
                >Correo electrónico</label
              >
              <div class="mt-1">
                <input
                  type="email"
                  name="email"
                  id="email"
                  class="py-3 px-4 block w-full shadow-sm focus:ring-brand-primary focus:border-brand-primary border-gray-300 rounded-md bg-white border outline-none"
                  placeholder="juan@gomeriasureste.com"
                />
              </div>
            </div>

            <div>
              <label
                for="company"
                class="block text-sm font-medium text-gray-700"
                >Empresa / Razón Social</label
              >
              <div class="mt-1">
                <input
                  type="text"
                  name="company"
                  id="company"
                  class="py-3 px-4 block w-full shadow-sm focus:ring-brand-primary focus:border-brand-primary border-gray-300 rounded-md bg-white border outline-none"
                  placeholder="Nombre de su taller o distribuidora"
                />
              </div>
            </div>

            <div>
              <label
                for="message"
                class="block text-sm font-medium text-gray-700"
                >Mensaje o Pedido Inicial</label
              >
              <div class="mt-1">
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  class="py-3 px-4 block w-full shadow-sm focus:ring-brand-primary focus:border-brand-primary border-gray-300 rounded-md bg-white border outline-none resize-none"
                  placeholder="Indique qué tipo de contrapesos busca y cantidades aproximadas..."
                ></textarea>
              </div>
            </div>

            <div>
              <button
                type="button"
                class="w-full inline-flex justify-center items-center px-6 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-brand-primary hover:bg-brand-primaryHover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-primary transition-colors"
              >
                Solicitar Presupuesto
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
