---
interface Props {
  title: string;
  imgSrc: string;
}

const { title, imgSrc } = Astro.props;
---

<div
  class="bg-white rounded-xl shadow-sm border border-orange-100 overflow-hidden hover:shadow-md transition-shadow group"
>
  <div
    class="bg-orange-50 aspect-square flex items-center justify-center p-6 group-hover:bg-orange-200 transition-colors"
  >
    <img
      src={imgSrc}
      alt={title}
      class="w-full h-full object-contain mix-blend-multiply drop-shadow-sm transition-transform group-hover:scale-110"
    />
  </div>
  <div class="p-6">
    <h3
      class="text-lg font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors"
    >
      {title}
    </h3>
    <p class="text-sm text-gray-500 line-clamp-2">
      <slot />
    </p>
  </div>
</div>
