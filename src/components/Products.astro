---

---

<section
  id="productos"
  class="py-20 bg-gray-50 border-t border-gray-100 border-b min-h-screen flex flex-col justify-center"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2
        class="text-base font-semibold text-brand-primary tracking-wide uppercase"
      >
        Catálogo Estandarizado
      </h2>
      <p
        class="mt-2 text-3xl leading-8 font-black tracking-tight text-brand-dark sm:text-4xl"
      >
        Nuestras Soluciones
      </p>
      <p class="mt-4 max-w-2xl text-xl text-gray-500 mx-auto">
        Fabricados con plomo de primera fundición, garantizando el balanceo
        ideal para cada tipo de rodado.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Producto 1 -->
      <div
        class="bg-white rounded-xl shadow-sm border border-orange-100 overflow-hidden hover:shadow-md transition-shadow group"
      >
        <div
          class="bg-orange-50 aspect-square flex items-center justify-center p-6 group-hover:bg-orange-100 transition-colors"
        >
          <img
            src="/contrapeso-autoadesivo.png"
            alt="Contrapeso Autoadhesivo"
            class="w-full h-full object-contain mix-blend-multiply drop-shadow-sm transition-transform group-hover:scale-105"
          />
        </div>
        <div class="p-6">
          <h3
            class="text-lg font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors"
          >
            Contrapeso Autoadhesivo
          </h3>
          <p class="text-sm text-gray-500 line-clamp-2">
            Cinta doble faz de alta resistencia. Tiras fraccionables para
            llantas de aleación en autos y camionetas.
          </p>
        </div>
      </div>

      <!-- Producto 2 -->
      <div
        class="bg-white rounded-xl shadow-sm border border-orange-100 overflow-hidden hover:shadow-md transition-shadow group"
      >
        <div
          class="bg-orange-50 aspect-square flex items-center justify-center p-6 group-hover:bg-orange-100 transition-colors"
        >
          <img
            src="/contrapeso-universal.png"
            alt="Contrapeso universal de plomo (Clip)"
            class="w-full h-full object-contain mix-blend-multiply drop-shadow-sm transition-transform group-hover:scale-105"
          />
        </div>
        <div class="p-6">
          <h3
            class="text-lg font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors"
          >
            Contrapeso universal de plomo (Clip)
          </h3>
          <p class="text-sm text-gray-500 line-clamp-2">
            Clip de plomo. Diseñado para llantas de acero con agarre seguro ante
            vibraciones.
          </p>
        </div>
      </div>

      <!-- Producto 3 -->
      <div
        class="bg-white rounded-xl shadow-sm border border-orange-100 overflow-hidden hover:shadow-md transition-shadow group"
      >
        <div
          class="bg-orange-50 aspect-square flex items-center justify-center p-6 group-hover:bg-orange-100 transition-colors"
        >
          <img
            src="/contrapeso-aleación.png"
            alt="Contrapeso Aleación"
            class="w-full h-full object-contain mix-blend-multiply drop-shadow-sm transition-transform group-hover:scale-105"
          />
        </div>
        <div class="p-6">
          <h3
            class="text-lg font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors"
          >
            Contrapeso Aleación
          </h3>
          <p class="text-sm text-gray-500 line-clamp-2">
            Descripción del producto .
          </p>
        </div>
      </div>
    </div>

    <div class="mt-12 text-center">
      <a
        href="/public/catalogo-contrapesos-2026.pdf"
        download
        class="text-brand-primary font-semibold hover:text-brand-primaryHover flex items-center justify-center"
      >
        Ver ficha técnica completa en el PDF
        <svg
          class="w-4 h-4 ml-1"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
        >
      </a>
    </div>
  </div>
</section>
