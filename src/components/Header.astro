---

---

<div class="fixed top-0 w-full z-50 transition-all duration-300">
  <header
    id="main-header"
    class="w-full bg-transparent bg-white/80 backdrop-blur-sm shadow-sm border-b border-gray-100 transition-all duration-300 relative z-10"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-24">
        <!-- Logo -->
        <div class="flex-shrink-0 flex items-center">
          <a href={import.meta.env.BASE_URL}>
            <img
              src={`${import.meta.env.BASE_URL}/logo-tc-icon.svg`}
              alt="TC Contrapesos"
              class="h-20 w-auto drop-shadow-sm"
            />
          </a>
        </div>

        <!-- Desktop Navigation -->
        <nav class="hidden md:flex space-x-8 items-center">
          <a
            href="#inicio"
            class="text-gray-600 hover:text-brand-primary font-medium transition-colors"
            >Inicio</a
          >
          <a
            href="#nosotros"
            class="text-gray-600 hover:text-brand-primary font-medium transition-colors"
            >Nosotros</a
          >
          <a
            href="#productos"
            class="text-gray-600 hover:text-brand-primary font-medium transition-colors"
            >Productos</a
          >
          <a
            href="#contacto"
            class="text-gray-600 hover:text-brand-primary font-medium transition-colors"
            >Contacto</a
          >

          <a
            href={`${import.meta.env.BASE_URL}/catalogo-contrapesos-2026.pdf`}
            download
            class="ml-8 inline-flex items-center justify-center px-6 py-2.5 border
          border-transparent rounded-md shadow-sm text-sm font-medium text-white
          bg-brand-primary hover:bg-brand-primaryHover focus:outline-none focus:ring-2
          focus:ring-offset-2 focus:ring-brand-primary transition-colors"
          >
            Descargar Catálogo
          </a>
        </nav>

        <!-- Mobile menu button -->
        <div class="flex md:hidden items-center">
          <button
            id="mobile-menu-button"
            type="button"
            class="text-gray-500 hover:text-gray-600 focus:outline-none"
            aria-label="Abrir menú"
          >
            <svg
              class="h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div
      class="md:hidden absolute w-full left-0 top-full bg-transparent bg-white/80 backdrop-blur-sm shadow-sm border-b border-gray-100 overflow-hidden transition-all duration-300 ease-out opacity-0 pointer-events-none"
      style="max-height: 0px;"
      id="mobile-menu"
    >
      <div class="px-4 py-6 space-y-4 flex flex-col items-end text-right">
        <a
          href="#inicio"
          class="text-gray-600 hover:text-brand-primary font-medium text-lg transition-colors mobile-link"
          >Inicio</a
        >
        <a
          href="#nosotros"
          class="text-gray-600 hover:text-brand-primary font-medium text-lg transition-colors mobile-link"
          >Nosotros</a
        >
        <a
          href="#productos"
          class="text-gray-600 hover:text-brand-primary font-medium text-lg transition-colors mobile-link"
          >Productos</a
        >
        <a
          href="#contacto"
          class="text-gray-600 hover:text-brand-primary font-medium text-lg transition-colors mobile-link"
          >Contacto</a
        >

        <a
          href={`${import.meta.env.BASE_URL}/catalogo-contrapesos-2026.pdf`}
          download
          class="mt-4 inline-flex justify-center py-3 px-6 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-brand-primary hover:bg-brand-primaryHover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-primary transition-colors mobile-link"
        >
          Descargar Catálogo
        </a>
      </div>
    </div>
  </header>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const mainHeader = document.getElementById("main-header");
      const mobileMenuButton = document.getElementById("mobile-menu-button");
      const mobileMenu = document.getElementById("mobile-menu");
      const mobileLinks = document.querySelectorAll(".mobile-link");
      let isMenuOpen = false;

      /** @param {boolean} open */
      const toggleMenu = (open: boolean) => {
        if (!mobileMenu) return;
        isMenuOpen = open;
        if (isMenuOpen) {
          // Open
          mobileMenu.style.maxHeight = mobileMenu.scrollHeight + "px";
          mobileMenu.classList.remove("opacity-0", "pointer-events-none");
          mobileMenu.classList.add("opacity-100", "pointer-events-auto");

          // Hide header border & shadow to remove the line
          if (mainHeader) {
            mainHeader.classList.replace(
              "border-gray-100",
              "border-transparent",
            );
            mainHeader.classList.replace("shadow-sm", "shadow-none");
          }
        } else {
          // Close
          mobileMenu.style.maxHeight = "0px";
          mobileMenu.classList.remove("opacity-100", "pointer-events-auto");
          mobileMenu.classList.add("opacity-0", "pointer-events-none");

          // Restore header border & shadow
          if (mainHeader) {
            mainHeader.classList.replace(
              "border-transparent",
              "border-gray-100",
            );
            mainHeader.classList.replace("shadow-none", "shadow-sm");
          }
        }
      };

      if (mobileMenuButton && mobileMenu) {
        mobileMenuButton.addEventListener("click", () => {
          toggleMenu(!isMenuOpen);
        });

        mobileLinks.forEach((link) => {
          link.addEventListener("click", () => {
            toggleMenu(false);
          });
        });
      }
    });
  </script>
</div>
