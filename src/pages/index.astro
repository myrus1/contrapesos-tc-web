---
import Layout from "../layouts/Layout.astro";
---

<Layout title="TC Contrapesos | Fabricación y Venta Mayorista">
    <!-- 1. Header/Nav -->
    <header
        class="fixed top-3 w-full bg-transparent bg-white/80 backdrop-blur-sm shadow-sm z-50 border-b border-gray-100"
    >
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <!-- Logo -->
                <div class="flex-shrink-0 flex items-center">
                    <a href="#">
                        <img
                            src="/logo-tc.svg"
                            alt="TC Contrapesos"
                            class="h-20 w-auto drop-shadow-sm"
                        />
                    </a>
                </div>

                <!-- Desktop Navigation -->
                <nav class="hidden md:flex space-x-8 items-center">
                    <a
                        href="#inicio"
                        class="text-gray-600 hover:text-brand-primary font-medium transition-colors"
                        >Inicio</a
                    >
                    <a
                        href="#nosotros"
                        class="text-gray-600 hover:text-brand-primary font-medium transition-colors"
                        >Nosotros</a
                    >
                    <a
                        href="#productos"
                        class="text-gray-600 hover:text-brand-primary font-medium transition-colors"
                        >Productos</a
                    >
                    <a
                        href="#contacto"
                        class="text-gray-600 hover:text-brand-primary font-medium transition-colors"
                        >Contacto</a
                    >

                    <a
                        href="/public/catalogo-contrapesos-2026.pdf"
                        download
                        class="ml-8 inline-flex items-center justify-center px-6 py-2.5 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-brand-primary hover:bg-brand-primaryHover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-primary transition-colors"
                    >
                        Descargar Catálogo
                    </a>
                </nav>

                <!-- Mobile menu button (visual placeholder) -->
                <div class="flex md:hidden items-center">
                    <button
                        type="button"
                        class="text-gray-500 hover:text-gray-600 focus:outline-none"
                        aria-label="Abrir menú"
                    >
                        <svg
                            class="h-6 w-6"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <main>
        <!-- 2. Hero Section -->
        <section
            id="inicio"
            class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden bg-brand-dark"
        >
            <div class="absolute inset-0 z-0">
                <img
                    src="https://imgs.search.brave.com/PtDX8mDDw1yHL2iXhLfut6MrlfLLcjWJtAD5OiJL78E/rs:fit:860:0:0:0/g:ce/aHR0cHM6Ly9yZXZv/c2hvcC5jb20ucGUv/d3AtY29udGVudC91/cGxvYWRzLzIwMjQv/MTEvYWxpbmVhY2lv/bi1sbGFudGFzLWRl/ZmluaWNpb24ucG5n"
                    alt="Balanceo de rueda"
                    class="w-full h-full object-cover opacity-40"
                />
            </div>
            <div
                class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center"
            >
                <span
                    class="inline-block py-1 px-3 rounded-full bg-orange-100 text-brand-primaryHover text-sm font-semibold tracking-wider mb-6 uppercase"
                >
                    Fabricación Nacional
                </span>
                <h1
                    class="text-4xl tracking-tight font-black text-white drop-shadow-md sm:text-5xl md:text-6xl max-w-4xl mx-auto leading-tight"
                >
                    Contrapesos de Plomo de Alta Precisión para <span
                        class="text-brand-primary drop-shadow-sm"
                        >Balanceo Automotor</span
                    >
                </h1>
                <p
                    class="mt-6 max-w-2xl mx-auto text-xl text-gray-200 font-medium drop-shadow-sm"
                >
                    Soluciones robustas y confiables. Venta exclusiva por mayor
                    para gomerías, talleres y red de distribuidores en todo el
                    país.
                </p>
                <div
                    class="mt-10 max-w-sm mx-auto sm:max-w-none sm:flex sm:justify-center gap-4"
                >
                    <a
                        href="/public/catalogo-contrapesos-2026.pdf"
                        download
                        class="w-full flex items-center justify-center px-8 py-4 border border-transparent text-base font-semibold rounded-md text-white bg-brand-primary hover:bg-brand-primaryHover md:py-4 md:text-lg md:px-10 shadow-lg hover:shadow-xl transition-all h-14 sm:w-auto"
                    >
                        <svg
                            class="w-5 h-5 mr-2"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                            ></path></svg
                        >
                        Descargar Catálogo (PDF)
                    </a>
                    <a
                        href="#contacto"
                        class="w-full flex items-center justify-center px-8 py-4 border-2 border-white text-base font-semibold rounded-md text-white bg-transparent hover:bg-white hover:text-brand-dark md:py-4 md:text-lg md:px-10 transition-colors h-14 sm:w-auto mt-4 sm:mt-0"
                    >
                        Hacer un pedido
                    </a>
                </div>
            </div>
        </section>

        <!-- 3. Sobre Nosotros -->
        <section id="nosotros" class="py-20 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
                    <div>
                        <h2
                            class="text-3xl font-black text-brand-dark tracking-tight sm:text-4xl mb-6"
                        >
                            5 Años de Trayectoria Industrial
                        </h2>
                        <div class="prose prose-lg text-gray-500">
                            <p class="mb-4">
                                En TC Contrapesos nos dedicamos a la fabricación
                                de contrapesos de plomo estandarizados y a
                                medida para el balanceo vehicular. Nuestra
                                planta operativa cuenta con procesos
                                estructurados para garantizar entregas en
                                volumen sin comprometer la tolerancia y el peso
                                exacto.
                            </p>
                            <p>
                                Entendemos las necesidades del mecanico y gomero
                                argentino. Por eso, nuestros productos aseguran
                                una adherencia perfecta y un calce preciso,
                                optimizando el tiempo de trabajo en el taller y
                                prolongando la vida útil del neumático.
                            </p>
                        </div>

                        <div class="mt-8 grid grid-cols-2 gap-4">
                            <div class="border-l-4 border-brand-primary pl-4">
                                <p class="text-2xl font-bold text-brand-dark">
                                    +500
                                </p>
                                <p
                                    class="text-sm font-medium text-gray-500 uppercase"
                                >
                                    Talleres abastecidos
                                </p>
                            </div>
                            <div class="border-l-4 border-brand-primary pl-4">
                                <p class="text-2xl font-bold text-brand-dark">
                                    100%
                                </p>
                                <p
                                    class="text-sm font-medium text-gray-500 uppercase"
                                >
                                    Garantía de calidad
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="mt-12 lg:mt-0">
                        <!-- Placeholder Imagen Fabrica -->
                        <div
                            class="bg-orange-50/50 border border-orange-100 aspect-video rounded-lg shadow-inner flex items-center justify-center relative overflow-hidden group"
                        >
                            <div
                                class="absolute inset-0 bg-brand-primary/5 group-hover:bg-transparent transition-colors duration-300"
                            >
                            </div>
                            <span
                                class="text-orange-300 font-medium text-lg flex flex-col items-center"
                            >
                                <svg
                                    class="w-12 h-12 mb-2 opacity-70"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    xmlns="http://www.w3.org/2000/svg"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                                    ></path></svg
                                >
                                Imagen Planta Industrial
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 4. Productos Destacados -->
        <section
            id="productos"
            class="py-20 bg-gray-50 border-t border-gray-100 border-b"
        >
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center max-w-3xl mx-auto mb-16">
                    <h2
                        class="text-base font-semibold text-brand-primary tracking-wide uppercase"
                    >
                        Catálogo Estandarizado
                    </h2>
                    <p
                        class="mt-2 text-3xl leading-8 font-black tracking-tight text-brand-dark sm:text-4xl"
                    >
                        Nuestras Soluciones
                    </p>
                    <p class="mt-4 max-w-2xl text-xl text-gray-500 mx-auto">
                        Fabricados con plomo de primera fundición, garantizando
                        el balanceo ideal para cada tipo de rodado.
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <!-- Producto 1 -->
                    <div
                        class="bg-white rounded-xl shadow-sm border border-orange-100 overflow-hidden hover:shadow-md transition-shadow group"
                    >
                        <div
                            class="bg-orange-50 aspect-square flex items-center justify-center p-6 group-hover:bg-orange-100 transition-colors"
                        >
                            <span
                                class="text-orange-300 font-medium whitespace-nowrap overflow-hidden text-ellipsis w-full text-center"
                                >Img Autoadhesivo</span
                            >
                        </div>
                        <div class="p-6">
                            <h3
                                class="text-lg font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors"
                            >
                                Contrapeso Autoadhesivo
                            </h3>
                            <p class="text-sm text-gray-500 line-clamp-2">
                                Cinta doble faz de alta resistencia. Tiras
                                fraccionables para llantas de aleación en autos
                                y camionetas.
                            </p>
                        </div>
                    </div>

                    <!-- Producto 2 -->
                    <div
                        class="bg-white rounded-xl shadow-sm border border-orange-100 overflow-hidden hover:shadow-md transition-shadow group"
                    >
                        <div
                            class="bg-orange-50 aspect-square flex items-center justify-center p-6 group-hover:bg-orange-100 transition-colors"
                        >
                            <span
                                class="text-orange-300 font-medium whitespace-nowrap overflow-hidden text-ellipsis w-full text-center"
                                >Img Estándar</span
                            >
                        </div>
                        <div class="p-6">
                            <h3
                                class="text-lg font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors"
                            >
                                Contrapeso Estándar (Clip)
                            </h3>
                            <p class="text-sm text-gray-500 line-clamp-2">
                                Clip de acero templado. Diseñado para llantas de
                                chapa tradicionales con agarre seguro ante
                                vibraciones.
                            </p>
                        </div>
                    </div>

                    <!-- Producto 3 -->
                    <div
                        class="bg-white rounded-xl shadow-sm border border-orange-100 overflow-hidden hover:shadow-md transition-shadow group"
                    >
                        <div
                            class="bg-orange-50 aspect-square flex items-center justify-center p-6 group-hover:bg-orange-100 transition-colors"
                        >
                            <span
                                class="text-orange-300 font-medium whitespace-nowrap overflow-hidden text-ellipsis w-full text-center"
                                >Img Camión</span
                            >
                        </div>
                        <div class="p-6">
                            <h3
                                class="text-lg font-bold text-gray-900 mb-2 group-hover:text-brand-primary transition-colors"
                            >
                                Contrapeso Línea Pesada
                            </h3>
                            <p class="text-sm text-gray-500 line-clamp-2">
                                Gramajes mayores especiales para transporte de
                                carga, camiones y maquinaria agrícola.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="mt-12 text-center">
                    <a
                        href="/public/catalogo-contrapesos-2026.pdf"
                        download
                        class="text-brand-primary font-semibold hover:text-brand-primaryHover flex items-center justify-center"
                    >
                        Ver ficha técnica completa en el PDF
                        <svg
                            class="w-4 h-4 ml-1"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
                        >
                    </a>
                </div>
            </div>
        </section>

        <!-- 5. Contacto -->
        <section id="contacto" class="py-20 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <h2 class="text-3xl font-black text-brand-dark sm:text-4xl">
                        Hablemos de su Pedido
                    </h2>
                    <p class="mt-4 text-lg text-gray-500">
                        Cotizaciones por volumen para distribuidores y talleres
                        a nivel nacional.
                    </p>
                </div>

                <div
                    class="max-w-5xl mx-auto bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden"
                >
                    <div class="grid grid-cols-1 md:grid-cols-2">
                        <!-- Columna Izquierda: Datos -->
                        <div
                            class="bg-brand-dark p-10 text-white flex flex-col justify-between relative overflow-hidden"
                        >
                            <div
                                class="absolute -bottom-24 -right-24 w-64 h-64 bg-brand-primary rounded-full opacity-10 blur-3xl"
                            >
                            </div>

                            <div class="relative z-10">
                                <h3 class="text-2xl font-bold mb-6">
                                    Contacto Directo
                                </h3>
                                <p class="text-gray-300 mb-8 max-w-sm">
                                    Nuestro equipo de ventas comerciales le
                                    responderá a la brevedad con la lista de
                                    precios mayorista actualizada.
                                </p>

                                <div class="space-y-6">
                                    <a
                                        href="tel:+541112345678"
                                        class="flex items-start group"
                                    >
                                        <div
                                            class="flex-shrink-0 bg-white/5 border border-white/10 p-3 rounded-lg group-hover:bg-brand-primary group-hover:border-brand-primary transition-colors"
                                        >
                                            <svg
                                                class="w-6 h-6 text-orange-400 group-hover:text-white transition-colors"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                                xmlns="http://www.w3.org/2000/svg"
                                                ><path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                                ></path></svg
                                            >
                                        </div>
                                        <div class="ml-4">
                                            <p
                                                class="text-sm font-medium text-gray-400"
                                            >
                                                Teléfono (Ventas)
                                            </p>
                                            <p
                                                class="text-lg font-semibold mt-1"
                                            >
                                                +54 11 1234-5678
                                            </p>
                                        </div>
                                    </a>

                                    <a
                                        href="mailto:ventas@tc-contrapesos.com.ar"
                                        class="flex items-start group"
                                    >
                                        <div
                                            class="flex-shrink-0 bg-white/5 border border-white/10 p-3 rounded-lg group-hover:bg-brand-primary group-hover:border-brand-primary transition-colors"
                                        >
                                            <svg
                                                class="w-6 h-6 text-orange-400 group-hover:text-white transition-colors"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                                xmlns="http://www.w3.org/2000/svg"
                                                ><path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                                ></path></svg
                                            >
                                        </div>
                                        <div class="ml-4">
                                            <p
                                                class="text-sm font-medium text-gray-400"
                                            >
                                                Correo Electrónico
                                            </p>
                                            <p
                                                class="text-lg font-semibold mt-1 group-hover:text-brand-primary transition-colors"
                                            >
                                                ventas@tc-contrapesos.com.ar
                                            </p>
                                        </div>
                                    </a>

                                    <div class="flex items-start">
                                        <div
                                            class="flex-shrink-0 bg-white/5 border border-white/10 p-3 rounded-lg"
                                        >
                                            <svg
                                                class="w-6 h-6 text-gray-400"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                                xmlns="http://www.w3.org/2000/svg"
                                                ><path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                                ></path><path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                                ></path></svg
                                            >
                                        </div>
                                        <div class="ml-4">
                                            <p
                                                class="text-sm font-medium text-gray-400"
                                            >
                                                Planta Industrial
                                            </p>
                                            <p
                                                class="text-lg font-semibold mt-1"
                                            >
                                                Parque Industrial Pilar<br
                                                /><span
                                                    class="text-sm text-gray-400"
                                                    >Buenos Aires, Argentina</span
                                                >
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Columna Derecha: Formulario -->
                        <div class="p-10 bg-orange-50/30">
                            <form action="#" method="POST" class="space-y-6">
                                <div>
                                    <label
                                        for="name"
                                        class="block text-sm font-medium text-gray-700"
                                        >Nombre completo</label
                                    >
                                    <div class="mt-1">
                                        <input
                                            type="text"
                                            name="name"
                                            id="name"
                                            class="py-3 px-4 block w-full shadow-sm focus:ring-brand-primary focus:border-brand-primary border-gray-300 rounded-md bg-white border outline-none"
                                            placeholder="Ej: Juan Pérez"
                                        />
                                    </div>
                                </div>

                                <div>
                                    <label
                                        for="email"
                                        class="block text-sm font-medium text-gray-700"
                                        >Correo electrónico</label
                                    >
                                    <div class="mt-1">
                                        <input
                                            type="email"
                                            name="email"
                                            id="email"
                                            class="py-3 px-4 block w-full shadow-sm focus:ring-brand-primary focus:border-brand-primary border-gray-300 rounded-md bg-white border outline-none"
                                            placeholder="juan@gomeriasureste.com"
                                        />
                                    </div>
                                </div>

                                <div>
                                    <label
                                        for="company"
                                        class="block text-sm font-medium text-gray-700"
                                        >Empresa / Razón Social</label
                                    >
                                    <div class="mt-1">
                                        <input
                                            type="text"
                                            name="company"
                                            id="company"
                                            class="py-3 px-4 block w-full shadow-sm focus:ring-brand-primary focus:border-brand-primary border-gray-300 rounded-md bg-white border outline-none"
                                            placeholder="Nombre de su taller o distribuidora"
                                        />
                                    </div>
                                </div>

                                <div>
                                    <label
                                        for="message"
                                        class="block text-sm font-medium text-gray-700"
                                        >Mensaje o Pedido Inicial</label
                                    >
                                    <div class="mt-1">
                                        <textarea
                                            id="message"
                                            name="message"
                                            rows="4"
                                            class="py-3 px-4 block w-full shadow-sm focus:ring-brand-primary focus:border-brand-primary border-gray-300 rounded-md bg-white border outline-none resize-none"
                                            placeholder="Indique qué tipo de contrapesos busca y cantidades aproximadas..."
                                        ></textarea>
                                    </div>
                                </div>

                                <div>
                                    <button
                                        type="button"
                                        class="w-full inline-flex justify-center items-center px-6 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-brand-primary hover:bg-brand-primaryHover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-primary transition-colors"
                                    >
                                        Solicitar Presupuesto
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- 6. Footer -->
    <footer class="bg-gray-900 border-t border-gray-800">
        <div
            class="max-w-7xl mx-auto py-12 px-4 sm:px-6 md:flex md:items-center md:justify-between lg:px-8"
        >
            <div
                class="flex justify-center space-x-6 md:order-2 text-sm text-gray-400"
            >
                <p>
                    Venta exclusiva a red de distribuidores y talleres
                    registrados.
                </p>
            </div>
            <div
                class="mt-8 md:mt-0 md:order-1 flex items-center justify-center md:justify-start"
            >
                <span class="text-xl font-bold text-white tracking-tight mr-4">
                    TC <span class="text-brand-primary">Contrapesos</span>
                </span>
                <p class="text-base text-gray-400">
                    &copy; {new Date().getFullYear()} Todos los derechos reservados.
                </p>
            </div>
        </div>
    </footer>
</Layout>
