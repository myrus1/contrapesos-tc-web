---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Contrapesos de plomo de alta precisión para balanceo automotor. Venta mayorista para gomerías, talleres y distribuidores."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}logo-tc.svg`}
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Google Fonts: Montserrat -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;900&display=swap"
      rel="stylesheet"
    />

    <!-- Tailwind CSS via CDN for rapid prototyping -->
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ["Montserrat", "sans-serif"],
            },
            colors: {
              brand: {
                dark: "#262626", // Neutral dark (Neutral 800) for high contrast and modern look
                primary: "#EF8E21", // Catalog Orange
                primaryHover: "#D37727", // Darker Catalog Orange for hover
                accent: "#3B82F6", // Light Blue (Blue 500)
                light: "#FEF6EE", // Very soft tint of catalog orange for backgrounds
              },
            },
          },
        },
      };
    </script>
  </head>
  <body
    class="font-sans text-gray-800 bg-white antialiased selection:bg-brand-primary selection:text-white"
  >
    <slot />
  </body>
</html>

<style is:global>
  /** Smooth scrolling para los anchor links */
  html {
    scroll-behavior: smooth;
  }

  /** Ajuste de padding si el header es fijo */
  section[id] {
    scroll-margin-top: 5rem;
  }
</style>
